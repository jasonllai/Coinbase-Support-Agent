# LLM (OpenAI-compatible Qwen endpoint)
LLM_BASE_URL=https://rsm-8430-finalproject.bjlkeng.io/v1
LLM_API_KEY=
LLM_MODEL=qwen3-30b-a3b-fp8
LLM_TIMEOUT_S=120

# Embeddings (downloaded on first run)
EMBEDDING_MODEL=BAAI/bge-small-en-v1.5

# Retrieval
RETRIEVAL_TOP_K=8
RERANK_TOP_N=4

# Demo gate (Streamlit)
DEMO_USERNAME=demo
DEMO_PASSWORD=changeme

# API (optional, Streamlit)
API_BASE=http://127.0.0.1:8000

# Paths
SQLITE_PATH=data/app.db
DATA_DIR=data
