# LLM (OpenAI-compatible Qwen endpoint)
LLM_BASE_URL=https://rsm-8430-finalproject.bjlkeng.io/v1
LLM_API_KEY=
LLM_MODEL=qwen3-30b-a3b-fp8
LLM_TIMEOUT_S=120

# Embeddings (remote API — @cf/baai/bge-base-en-v1.5, 768-dim)
EMBEDDING_BASE_URL=https://rsm-8430-a2.bjlkeng.io/v1
EMBEDDING_MODEL=@cf/baai/bge-base-en-v1.5
# EMBEDDING_API_KEY=  # leave blank to reuse LLM_API_KEY

# Retrieval
RETRIEVAL_TOP_K=8
RERANK_TOP_N=4

# Demo gate (Streamlit)
DEMO_USERNAME=coinbase
DEMO_PASSWORD=CoinbaseSupport2026!

# API (optional, Streamlit)
API_BASE=http://127.0.0.1:8000

# Paths
SQLITE_PATH=data/app.db
DATA_DIR=data
